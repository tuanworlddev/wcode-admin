# Port HTTP server lắng nghe (đặt sau reverse proxy HTTPS như Caddy/nginx)
PORT=8787

# Đường dẫn file SQLite (thư mục sẽ được tạo tự động)
DB_PATH=./data/license.db

# Token cho các endpoint /api/v1/admin/* và CLI — sinh bằng: openssl rand -hex 32
ADMIN_TOKEN=change-me

# Private key Ed25519 ký license file — sinh bằng: npm run keygen
LICENSE_PRIVATE_KEY_PATH=./keys/license-signing.key
